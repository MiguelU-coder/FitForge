# FitForge Monorepo - Root .env.example
# This file serves as a reference for common keys across the project.
# Individual .env files are located in:
# - ./backend/.env
# - ./admin_web/.env
# - ./ia_microservices/.env
# - ./fitforge_flutter/.env

# COMMON SHARED KEYS
# Must match across backend and ia_microservices
SUPABASE_URL="https://your-project.supabase.co"
REDIS_URL="redis://localhost:6379"
AI_SERVICE_SECRET="your-shared-internal-secret"
