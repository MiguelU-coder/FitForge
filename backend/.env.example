NODE_ENV=development
PORT=3000

# ── APP URLs ──────────────────────────────────────────────────────────────────
# URL of the frontend (where users login)
FRONTEND_URL="http://localhost:5173"
# URL of this backend API (used for Stripe redirects)
APP_URL="http://localhost:3000"

# ── DATABASE ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fitforge:password@localhost:5432/fitforge_dev?schema=public"
DATABASE_REPLICA_URL="postgresql://fitforge:password@localhost:5433/fitforge_dev?schema=public"

# ── REDIS ───────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── SUPABASE AUTH ──────────────────────────────────────────────────────────────
# Required for verifying Supabase-issued JWT tokens
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_JWT_SECRET="your-base64-encoded-jwt-secret-from-supabase"

# ── LOCAL JWT (fallback) ────────────────────────────────────────────────────────
# Used when Supabase auth is not configured
# Must match JWT_ACCESS_SECRET in ia_microservices/.env
JWT_ACCESS_SECRET="CHANGE_ME_MINIMUM_64_CHARS_FOR_512_BIT_SECURITY_xxxxxxxxxxxxxxxxxxx"
JWT_REFRESH_SECRET="CHANGE_ME_DIFFERENT_FROM_ACCESS_SECRET_xxxxxxxxxxxxxxxxxxxxxxxxxx"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── AI MICROSERVICE ─────────────────────────────────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="CHANGE_ME_SHARED_SECRET_FOR_AI_SERVICE"

# ── CORS (comma-separated) ─────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3001,exp://192.168.1.1:8081"

# ── EXTERNAL APIs ──────────────────────────────────────────────────────────────
# RapidAPI - ExerciseDB
EXERCISE_DB_API_KEY="YOUR_RAPID_API_KEY_HERE"
