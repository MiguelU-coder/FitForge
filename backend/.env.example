NODE_ENV=development
PORT= 3000

# ── APP URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
APP_URL="http://localhost:3000"

# ── DATABASE ───────────────────────────────────────────────────────────────────
# Prisma connection strings
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"
DATABASE_REPLICA_URL="postgresql://user:password@localhost:5433/db_name?schema=public"

# ── REDIS ───────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── SUPABASE AUTH ──────────────────────────────────────────────────────────────
# URL of your Supabase project
SUPABASE_URL="https://your-project.supabase.co"
# JWT Secret for verifying tokens (Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET="your-base64-encoded-jwt-secret"
# Service Role Key (Settings -> API -> service_role)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── LOCAL JWT (fallback) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="your-access-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── ARGON2 ─────────────────────────────────────────────────────────────────────
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=1

# ── AI MICROSERVICE ─────────────────────────────────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="your-shared-secret-with-ai-service"
AI_SERVICE_TIMEOUT_MS=30000

# ── STRIPE ─────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── EXTERNAL APIs ──────────────────────────────────────────────────────────────
# RapidAPI - ExerciseDB
EXERCISE_DB_API_KEY="your-rapidapi-key"

# ── STORAGE ────────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
