# ia_microservices/.env.example
# Copy to .env and fill in values

APP_ENV=development
APP_PORT=8000
# Generate with: openssl rand -base64 32
APP_SECRET="your-base64-app-secret-here-same-as-backend-shared-secret"

# ── AUTHENTICATION ──────────────────────────────────────────────────────────
# JWT Secret from NestJS backend (HS256)
# Must match JWT_ACCESS_SECRET in backend/.env
JWT_ACCESS_SECRET="your-backend-jwt-access-secret-here"

# Supabase URL for JWT verification (JWKS/ES256)
SUPABASE_URL="https://your-project.supabase.co"

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Redis (same instance as NestJS backend)
REDIS_URL="redis://localhost:6379"

# ── INTERNAL SERVICES ──────────────────────────────────────────────────────────
# NestJS backend URL (for internal calls from Python)
BACKEND_URL="http://localhost:3000"

# ── CACHE TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_RECOMMENDATION=3600
CACHE_TTL_VOLUME=1800

# ── AI MODEL SETTINGS ─────────────────────────────────────────────────────────
MIN_SESSIONS_FOR_ANALYSIS=3
PROGRESSIVE_OVERLOAD_THRESHOLD=0.85
