# ai-service/.env.example
# Copy to .env and fill in values

APP_ENV=development
APP_PORT=8000
APP_SECRET=change_me_min_32_chars_random_string

# ── AUTHENTICATION (Supabase + NestJS) ───────────────────────────────────────
# Option 1: Supabase JWT verification (RS256/ES256 via JWKS)
# Required for verifying Supabase-issued tokens
SUPABASE_URL=https://your-project.supabase.co

# Option 2: NestJS backend JWT verification (HS256)
# Must match JWT_ACCESS_SECRET in backend/.env
JWT_ACCESS_SECRET=change_me_same_as_backend_jwt_access_secret

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Redis (same instance as NestJS backend)
REDIS_URL=redis://localhost:6379

# ── INTERNAL SERVICES ──────────────────────────────────────────────────────────
# NestJS backend URL (for internal calls)
BACKEND_URL=http://localhost:3000

# ── CACHE TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_RECOMMENDATION=3600   # 1 hour
CACHE_TTL_VOLUME=1800           # 30 min

# ── AI MODEL SETTINGS ─────────────────────────────────────────────────────────
MIN_SESSIONS_FOR_ANALYSIS=3     # min sessions before AI gives recommendations
PROGRESSIVE_OVERLOAD_THRESHOLD=0.85  # if avg RIR >= threshold of target, suggest increase
