# ── SUPABASE CONFIGURATION ──────────────────────────────────────────────────
# Project URL (Settings -> API -> Project URL)
SUPABASE_URL="https://your-project.supabase.co"
# Anon root key (Settings -> API -> anon/public)
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── RAPID API (ExerciseDB) ──────────────────────────────────────────────────
X_RAPIDAPI_KEY="your-rapidapi-key"
X_RAPIDAPI_HOST="ai-workout-planner-exercise-fitness-nutrition-guide.p.rapidapi.com"

# ── BACKEND ─────────────────────────────────────────────────────────────────
# URL for the NestJS API
BACKEND_API_URL="http://localhost:3000/api/v1"

# ── AI MICROSERVICES (Python / AI) ──────────────────────────────────────────
# URL for the main AI microservice
AI_MICROSERVICES_URL="http://localhost:8000"
# URL for the AI Coach microservice
AI_COACH_URL="http://localhost:8001"
